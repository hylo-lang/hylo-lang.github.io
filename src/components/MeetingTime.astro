---
import NormalButton from './NormalButton.astro';
import { meetingLink } from '../links.ts';
import { Video, Calendar } from '@lucide/astro';

export interface Props {
  startTime: string; // "HH:MM" 24-hour
  endTime: string;   // "HH:MM" 24-hour
  timezone: string;  // IANA, e.g. "America/Los_Angeles"
  fallbackText?: string;
}

const { startTime, endTime, timezone, fallbackText = 'Meeting time' } = Astro.props;
---

<div
  class="flex gap-4 flex-wrap"
  id="meeting-time-root"
  data-start-time={startTime}
  data-end-time={endTime}
  data-timezone={timezone}
  data-fallback-text={fallbackText}
>
  <NormalButton href={meetingLink}>
    <Video/>
    <span id="meeting-time" class="font-medium leading-snug inline-block">
      {fallbackText}
    </span>
  </NormalButton>

  <span id="meeting-calendar" hidden>
    <NormalButton href="#">
      <Calendar/>
      <span>Add to Calendar</span>
    </NormalButton>
  </span>
</div>

<script>
import { meetingLink } from '../links.ts';
import {
  getNextMeetingDate,
  meetingInstant,
  renderMeetingDescription,
} from './meetingTime.ts';

function toGCalDate(date: Date): string {
  return date.toISOString().replace(/[-:]/g, '').split('.')[0] + 'Z';
}

function buildCalendarUrl(start: Date, end: Date): string {
  const params = new URLSearchParams({
    action: 'TEMPLATE',
    text: 'Hylo Developer Meeting',
    dates: `${toGCalDate(start)}/${toGCalDate(end)}`,
    details: 'Join the Hylo developer meeting',
    location: meetingLink,
  });
  return `https://calendar.google.com/calendar/render?${params}`;
}

function update() {
  const root = document.getElementById('meeting-time-root');
  const label = document.getElementById('meeting-time');
  const calWrap = document.getElementById('meeting-calendar');
  const calAnchor = calWrap?.querySelector('a');
  if (!root || !label || !calWrap || !calAnchor) return;

  const { startTime, endTime, timezone, fallbackText } = root.dataset;
  if (!startTime || !endTime || !timezone) return;

  try {
    const now = new Date();
    const meetingDate = getNextMeetingDate(now, startTime, timezone);

    const { title, details } = renderMeetingDescription({
      now,
      meetingDate,
      startTime,
      endTime,
      sourceTimezone: timezone,
      userTimeZone: Intl.DateTimeFormat().resolvedOptions().timeZone,
      title: fallbackText || 'Meeting time',
    });
    label.innerHTML =
      `${title}<br><small style="opacity: 0.7; font-size: 0.85em;">${details}</small>`;

    calAnchor.href = buildCalendarUrl(
      meetingInstant(meetingDate, startTime, timezone),
      meetingInstant(meetingDate, endTime, timezone),
    );
    calWrap.hidden = false;
  } catch (error) {
    console.error('Meeting time update failed:', error);
  }
}

if (document.readyState === 'loading') {
  document.addEventListener('DOMContentLoaded', update);
} else {
  update();
}
document.addEventListener('visibilitychange', () => {
  if (!document.hidden) update();
});
setInterval(update, 60 * 1000);
</script>
