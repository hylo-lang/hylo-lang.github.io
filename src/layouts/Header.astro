---
import LanguageSelect from '@astrojs/starlight/components/LanguageSelect.astro';
import Search from '@astrojs/starlight/components/Search.astro';
import SiteTitle from '@astrojs/starlight/components/SiteTitle.astro';
import SocialIcons from '@astrojs/starlight/components/SocialIcons.astro';
import ThemeSelect from 'starlight-theme-rapide/overrides/ThemeSelect.astro';

const navLinks = [
    { href: '/blog', label: 'Blog' },
    { href: '/docs/contributing/community/', label: 'Community' },
    { href: '/docs', label: 'Docs' },
    { href: '/docs/contributing/research-collab/', label: 'Research' },
    { href: '/docs/contributing', label: 'Contribute' },
];
---

<div class="header">
    <div class="title-wrapper sl-flex">
        <SiteTitle />
        <nav class="sl-hidden md:sl-flex primary-nav" aria-label="Primary">
            {navLinks.map(({ href, label }) => (
                <a href={href}>{label}</a>
            ))}
        </nav>
    </div>

    <div class="sl-hidden md:sl-flex print:hidden">
        <Search />
    </div>

    <div class="sl-hidden md:sl-flex print:hidden right-group">
        <div class="sl-flex social-icons">
            <SocialIcons />
        </div>
        <ThemeSelect />
        <LanguageSelect />
    </div>

    <details class="sl-flex md:sl-hidden print:hidden mobile-menu">
        <summary aria-label="Toggle menu">
            <span class="bar" aria-hidden="true"></span>
            <span class="bar" aria-hidden="true"></span>
            <span class="bar" aria-hidden="true"></span>
        </summary>
        <div class="panel">
            <Search />
            <nav aria-label="Primary">
                {navLinks.map(({ href, label }) => (
                    <a href={href}>{label}</a>
                ))}
            </nav>
            <div class="row">
                <div class="sl-flex social-icons">
                    <SocialIcons />
                </div>
                <ThemeSelect />
                <LanguageSelect />
            </div>
        </div>
    </details>
</div>

<style>
    @layer starlight.core {
        .header {
            display: flex;
            gap: var(--sl-nav-gap);
            justify-content: space-between;
            align-items: center;
            height: 100%;
        }

        .title-wrapper {
            overflow: clip;
            padding: 0.25rem;
            margin: -0.25rem;
            min-width: 0;
        }

        .primary-nav {
            gap: 0.25rem;
            align-items: center;
            padding-inline-start: 1rem;
        }

        .primary-nav a {
            padding: 0.25rem 0.5rem;
            border-radius: 0.25rem;
            color: inherit;
            text-decoration: none;
            white-space: nowrap;
        }

        .primary-nav a:hover,
        .primary-nav a:focus-visible {
            background: var(--sl-color-gray-6, var(--sl-color-gray-5));
            color: var(--sl-color-white);
        }

        .right-group,
        .social-icons {
            gap: 1rem;
            align-items: center;
        }

        .social-icons::after {
            content: '';
            height: 2rem;
            border-inline-end: 1px solid var(--sl-color-gray-5);
        }

        /* Mobile menu: native <details> + summary, no JS. */
        .mobile-menu {
            position: relative;
        }

        .mobile-menu > summary {
            list-style: none;
            display: inline-flex;
            flex-direction: column;
            justify-content: center;
            gap: 4px;
            width: 2.25rem;
            height: 2.25rem;
            padding: 0.5rem;
            border: 1px solid var(--sl-color-gray-5);
            border-radius: 0.375rem;
            cursor: pointer;
        }

        .mobile-menu > summary::-webkit-details-marker { display: none; }

        .mobile-menu .bar {
            display: block;
            height: 2px;
            background: currentColor;
            border-radius: 2px;
        }

        .mobile-menu .panel {
            position: absolute;
            top: calc(100% + 0.5rem);
            inset-inline-end: 0;
            min-width: min(18rem, 92vw);
            background: var(--sl-color-bg-nav);
            border: 1px solid var(--sl-color-gray-5);
            border-radius: 0.5rem;
            box-shadow: var(--sl-shadow-md);
            padding: 0.5rem;
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
        }

        .mobile-menu .panel nav {
            display: flex;
            flex-direction: column;
        }

        .mobile-menu .panel nav a {
            padding: 0.625rem 0.75rem;
            border-radius: 0.375rem;
            color: inherit;
            text-decoration: none;
        }

        .mobile-menu .panel nav a:hover,
        .mobile-menu .panel nav a:focus-visible {
            background: var(--sl-color-gray-6, var(--sl-color-gray-5));
            color: var(--sl-color-white);
        }

        .mobile-menu .row {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            border-top: 1px solid var(--sl-color-gray-5);
            padding: 0.5rem 0.5rem 0.25rem;
        }

        .mobile-menu .row .social-icons::after { display: none; }

        @media (min-width: 50rem) {
            .header {
                display: grid;
                grid-template-columns: 1fr auto auto;
                align-content: center;
            }
            .title-wrapper { justify-self: start; }
        }
    }

    /* On pages where Starlight renders its own sidebar hamburger, hide ours
       to avoid two toggles on mobile. Unlayered so it beats .sl-flex. */
    :global(html[data-has-sidebar]) .mobile-menu {
        display: none;
    }
</style>
